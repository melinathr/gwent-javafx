<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="view.DeckMenu"
            prefHeight="800.0" prefWidth="1200.0">
    <left>
        <VBox>
            <Label text="Available Cards"/>
            <ListView fx:id="availableCardsList" prefHeight="600.0" prefWidth="450.0"/>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="deckNameField" promptText="Enter deck name" maxWidth="200" />
            <Button text="Load Deck" onAction="#loadDeck"/>
            <Button text="Save Deck" onAction="#saveDeck"/>

            <Button fx:id="selectButton" text="Select Card"/>
            <Button fx:id="deleteButton" text="Delete Selected Cards"/>
            <Button fx:id="finalizeButton" text="Finalize Selection"/>

        </VBox>
    </center>

    <right>
        <VBox>
            <Label text="Selected Cards"/>
            <ListView fx:id="selectedCardsList" prefHeight="600.0" prefWidth="200.0"/>
        </VBox>
    </right>


</BorderPane>