<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.net.URL?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="view.RegisterMenu"
            id="registerPane"
            prefHeight="400.0" prefWidth="600.0">
    <stylesheets>
        <URL value="@../CSS/1.css"/>
    </stylesheets>

    <center>

        <VBox alignment="CENTER" spacing="20">
            <Label text="Register Menu" styleClass="title"/>
            <TextField fx:id="username" maxWidth="200" promptText="Your Username"/>
            <PasswordField fx:id="passwordField" maxWidth="200" promptText="Your Password"/>
            <PasswordField fx:id="passConfirmField" maxWidth="200" promptText="Confirm Password"/>
            <TextField fx:id="email" maxWidth="200" promptText="Your Email"/>
            <TextField fx:id="nickname" maxWidth="200" promptText="Your NickName"/>

            <Label text="Select Security Question" styleClass="subtitle"/>

            <ChoiceBox fx:id="securityQuestion" maxWidth="200" styleClass="choice-box">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="What is your pet's name?"/>
                        <String fx:value="What is your mother's maiden name?"/>
                        <String fx:value="What is your favorite color?"/>
                    </FXCollections>
                </items>
            </ChoiceBox>


            <TextField fx:id="securityAnswer" maxWidth="200" promptText="Your Answer"/>


            <HBox alignment="CENTER" spacing="15">
                <Button onMouseClicked="#register" text="Register" styleClass="button"/>
                <Button onMouseClicked="#back" text="Back" styleClass="button"/>
            </HBox>

        </VBox>

    </center>

</BorderPane>
